        <div class="picker-char cls-controller" onclick="selectChar(this)">コースティック</div>
        <div class="picker-char cls-controller" onclick="selectChar(this)">ワットソン</div>
        <div class="picker-char cls-controller" onclick="selectChar(this)">ランパート</div>
        <div class="picker-char cls-controller" onclick="selectChar(this)">カタリスト</div>
      </div>
    </div>
    <div class="picker-class">
      <div class="picker-class-label" style="background:#50a890">サポート</div>
      <div class="picker-chars">
        <div class="picker-char cls-support" onclick="selectChar(this)">ジブラルタル</div>
        <div class="picker-char cls-support" onclick="selectChar(this)">ライフライン</div>
        <div class="picker-char cls-support" onclick="selectChar(this)">ミラージュ</div>
        <div class="picker-char cls-support" onclick="selectChar(this)">ローバ</div>
        <div class="picker-char cls-support" onclick="selectChar(this)">ニューキャッスル</div>
        <div class="picker-char cls-support" onclick="selectChar(this)">コンジット</div>
      </div>
    </div>
  </div>
</div>
<script>


// Character picker
let activeCharCell = null;

document.querySelectorAll('.char-cell').forEach(td => {
  if (!td.classList.contains('c-0')) {
    td.style.cursor = 'pointer';
    td.addEventListener('click', function(e) {
      activeCharCell = this;
      const picker = document.getElementById('charPicker');
      picker.style.left = (e.clientX + window.scrollX) + 'px';
      picker.style.top = (e.clientY + window.scrollY + 8) + 'px';
      picker.classList.add('visible');
    });
  }
});

function selectChar(el) {
  const picker = document.getElementById('charPicker');
  const name = el.textContent;
  const cls = Array.from(el.classList).find(c => c.startsWith('cls-'));
  if (picker.dataset.mode === 'ban' && activeBanCell) {
    activeBanCell.textContent = name;
    activeBanCell.className = 'ban-cell ' + cls;
    const gameNum = parseInt(activeBanCell.dataset.game);
    applyBanCarryover(gameNum);
  } else if (activeCharCell) {
    activeCharCell.textContent = name;
    activeCharCell.className = 'char-cell ' + cls;
  }
  closePicker();
}




async function detectAllBans(input) {
  if (!input.files[0]) return;
  const status = document.getElementById('bulkStatus');
  status.textContent = '判定中...';

  const reader = new FileReader();
  reader.onload = async function(e) {
    const base64 = e.target.result.split(',')[1];
    const mediaType = input.files[0].type;

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 200,
          messages: [{
            role: 'user',
            content: [
              { type: 'image', source: { type: 'base64', media_type: mediaType, data: base64 } },
              { type: 'text', text: 'これはApex LegendsのLegend Bansの画像です。左から順番にBANされているキャラクターの日本語名をカンマ区切りで答えてください。必ずこのリストの中から選んでください：バンガロール、ヒューズ、アッシュ、マッドマギー、バリスティック、パスファインダー、レイス、オクタン、レヴナント、ホライゾン、オルター、ブラッドハウンド、クリプト、ヴァルキリー、シア、ヴァンテージ、コースティック、ワットソン、ランパート、カタリスト、ジブラルタル、ライフライン、ミラージュ、ローバ、ニューキャッスル、コンジット。例：バンガロール,レイス,コースティック,ライフライン,ヴァルキリー,シア' }
            ]
          }]
        })
      });
      const data = await response.json();
      const names = data.content[0].text.trim().split(',').map(n => n.trim());
      
      // Fill BAN cells for each game with same bans (all games share same ban)
      const banCells = document.querySelectorAll('.ban-cell');
      // Fill each game's ban cell (one per game = 8 cells, but we show per-game)
      // Actually put all detected bans into game 1's cell as combined text, 
      // or fill each game cell with respective ban if 8 detected, else fill all with list
      if (names.length <= 8) {
        banCells.forEach((cell, i) => {
          if (names[i]) cell.textContent = names[i];
        });
        status.textContent = '✅ ' + names.join('、') + ' を入力しました';
      } else {
        status.textContent = '✅ ' + names.join('、');
      }
    } catch(err) {
      status.textContent = '❌ エラーが発生しました';
      console.error(err);
    }
    input.value = '';
  };
  reader.readAsDataURL(input.files[0]);
}



const SPARROW_IMG = "";
async function detectBanBar(input) {
  if (!input.files[0]) return;
  const status = document.getElementById('detectStatus');
  status.textContent = '一括判定中...';

  const reader = new FileReader();
  reader.onload = async function(e) {
    const base64 = e.target.result.split(',')[1];
    const mediaType = input.files[0].type;
    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 200,
          messages: [{
            role: 'user',
            content: [
              { type: 'image', source: { type: 'base64', media_type: mediaType, data: base64 } },
              { type: 'text', text: 'これはApex LegendsのLegend Bansバー（試合前のBAN画面）のスクリーンショットです。横一列に小さなキャラクターのポートレートアイコンが並んでいます。左から順番に各アイコンのキャラクターを特定し、日本語名のみをカンマ区切りで答えてください。例：オルター,クリプト,コースティック,ヴァルキリー,シア,マッドマギー。必ず以下のリストの中から選んでください：バンガロール、ヒューズ、アッシュ、マッドマギー、バリスティック、パスファインダー、レイス、オクタン、レヴナント、ホライゾン、オルター、ブラッドハウンド、クリプト、ヴァルキリー、シア、ヴァンテージ、コースティック、ワットソン、ランパート、カタリスト、ジブラルタル、ライフライン、ミラージュ、ローバ、ニューキャッスル、コンジット。名前のみカンマ区切りで出力し、番号・説明・改行は一切不要です。' }
            ]
          }]
        })
      });
      const data = await response.json();
      const names = data.content[0].text.trim().split(',').map(n => n.trim());
      const banCells = document.querySelectorAll('.ban-cell');
      status.textContent = '✅ 確認してください';
      closePicker();
      showBanConfirm(names);
    } catch(err) {
      status.textContent = '❌ エラー';
    }
    input.value = '';
  };
  reader.readAsDataURL(input.files[0]);
}

async function detectCharFromImage(input) {
  if (!input.files[0]) return;
  const status = document.getElementById('detectStatus');
  status.textContent = '判定中...';

  const reader = new FileReader();
  reader.onload = async function(e) {
    const base64 = e.target.result.split(',')[1];
    const mediaType = input.files[0].type;

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 100,
          messages: [{
            role: 'user',
            content: [
              { type: 'image', source: { type: 'base64', media_type: mediaType, data: base64 } },
              { type: 'text', text: 'これはApex Legendsのキャラクター画像です。このキャラクターの日本語名を一言だけ答えてください。例：バンガロール。リストの中から選んでください：バンガロール、ヒューズ、アッシュ、マッドマギー、バリスティック、パスファインダー、レイス、オクタン、レヴナント、ホライゾン、オルター、ブラッドハウンド、クリプト、ヴァルキリー、シア、ヴァンテージ、コースティック、ワットソン、ランパート、カタリスト、ジブラルタル、ライフライン、ミラージュ、ローバ、ニューキャッスル、コンジット' }
            ]
          }]
        })
      });
      const data = await response.json();
      const name = data.content[0].text.trim();
      status.textContent = '✅ ' + name;
      if (activeBanCell) {
        activeBanCell.textContent = name;
        const gameNum = parseInt(activeBanCell.dataset.game);
        applyBanCarryover(gameNum);
        closePicker();
      }
    } catch(err) {
      status.textContent = '❌ エラー';
    }
    // Reset input
    input.value = '';
  };
  reader.readAsDataURL(input.files[0]);
}

function clearCell() {
  const picker = document.getElementById('charPicker');
  if (picker.dataset.mode === 'ban' && activeBanCell) {
    activeBanCell.textContent = '—';
    activeBanCell.className = 'ban-cell';
  } else if (activeCharCell) {
    activeCharCell.textContent = '—';
    activeCharCell.className = 'char-cell c-0';
  }
  closePicker();
}

function closePicker() {
  const picker = document.getElementById('charPicker');
  picker.classList.remove('visible');
  picker.dataset.mode = '';
  activeCharCell = null;
  activeBanCell = null;
}

document.addEventListener('click', function(e) {
  const picker = document.getElementById('charPicker');
  if (!picker.contains(e.target) && !e.target.classList.contains('char-cell')) {
    closePicker();
  }
});




// Ctrl+V paste image for BAN detection
document.getElementById('pasteTarget').addEventListener('paste', async function(e) {
  const picker = document.getElementById('charPicker');
  if (!picker.classList.contains('visible')) return;
  if (picker.dataset.mode !== 'ban') return;
  if (!activeBanCell) return;

  const items = e.clipboardData.items;
  for (let item of items) {
    if (item.type.startsWith('image/')) {
      e.preventDefault();
      const file = item.getAsFile();
      const status = document.getElementById('detectStatus');
      status.textContent = '判定中...';

      const reader = new FileReader();
      reader.onload = async function(ev) {
        const base64 = ev.target.result.split(',')[1];
        const mediaType = file.type;
        try {
          const response = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: 'claude-sonnet-4-20250514',
              max_tokens: 300,
              messages: [{
                role: 'user',
                content: [
                  { type: 'text', text: 'これはApex Legendsの新キャラクター「スパロー」の顔です。参照してください。' },
                  { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: SPARROW_IMG } },
                  { type: 'image', source: { type: 'base64', media_type: mediaType, data: base64 } },
                  { type: 'text', text: 'これはApex LegendsのLegend Bansバーです。画像が小さくても、髪型・シルエット・色・特徴から最善の判断をしてください。不鮮明でも必ず答えを出してください。左から順にキャラクターの日本語名のみをカンマ区切りで出力してください。前置き・説明・「不鮮明」などの言葉は一切不要。必ず以下から選択：バンガロール,ヒューズ,アッシュ,マッドマギー,バリスティック,パスファインダー,レイス,オクタン,レヴナント,ホライゾン,オルター,ブラッドハウンド,クリプト,ヴァルキリー,シア,ヴァンテージ,スパロー,コースティック,ワットソン,ランパート,カタリスト,ジブラルタル,ライフライン,ミラージュ,ローバ,ニューキャッスル,コンジット。出力例：オルター,クリプト,コースティック,ヴァルキリー,シア,マッドマギー' }
                ]
              }]
            })
          });
          const data = await response.json();
          console.log('API response:', JSON.stringify(data));
          if (data.error) throw new Error(data.error.message);
          if (!data.content || !data.content[0]) throw new Error('レスポンス空');
          const names = data.content[0].text.trim().split(',').map(n => n.trim());
          status.textContent = '✅ 確認してください';
          closePicker();
          showBanConfirm(names);
        } catch(err) {
          status.textContent = '❌ ' + (err.message || 'エラー');
          console.error('paste detect error:', err);
        }
      };
      reader.readAsDataURL(file);
      break;
    }
  }
});


let pendingBanNames = [];

function showBanConfirm(names) {
  pendingBanNames = names;
  const rowsEl = document.getElementById('banConfirmRows');
  rowsEl.innerHTML = '';
  names.forEach((name, i) => {
    const gameNum = i + 2; // starts from game 2
    if (gameNum > 8) return;
    const row = document.createElement('div');
    row.className = 'ban-confirm-row';
    row.innerHTML = `<span class="ban-confirm-label">GAME ${gameNum}</span>
      <input class="ban-confirm-input" data-idx="${i}" value="${name}" placeholder="—">`;
    rowsEl.appendChild(row);
  });
  document.getElementById('banConfirmOverlay').classList.add('visible');
}

function applyBanConfirm() {
  const inputs = document.querySelectorAll('.ban-confirm-input');
  const banCells = document.querySelectorAll('.ban-cell');
  inputs.forEach(input => {
    const i = parseInt(input.dataset.idx);
    const name = input.value.trim();
    if (banCells[i + 1] && name) banCells[i + 1].textContent = name || '—';
  });
  closeBanConfirm();
}

function closeBanConfirm() {
  document.getElementById('banConfirmOverlay').classList.remove('visible');
}


// Import system
const PLACEMENT_PTS = {1:12,2:9,3:7,4:5,5:4,6:3,7:2,8:2,9:1,10:1,11:1,12:1,13:1,14:1,15:1,16:0,17:0,18:0,19:0,20:0};
const PLAYER_MAP = {
  'lykq': 't', 'mo-mon': 'p', 'lible_ace': 'a', 'lible ace': 'a',
  'たろう': 't', 'pete wentz': 'p', 'あめじまん': 'a'
};
// Character JP mapping for import
const CHAR_MAP = {
  'newcastle':'ニューキャッスル','valkyrie':'ヴァルキリー','caustic':'コースティック',
  'bangalore':'バンガロール','seer':'シア','pathfinder':'パスファインダー',
  'ash':'アッシュ','rampart':'ランパート','madmaggie':'マッドマギー',
  'alter':'オルター','crypto':'クリプト','bloodhound':'ブラッドハウンド',
  'wraith':'レイス','octane':'オクタン','horizon':'ホライゾン',
  'revenant':'レヴナント','vantage':'ヴァンテージ','gibraltar':'ジブラルタル',
  'lifeline':'ライフライン','mirage':'ミラージュ','loba':'ローバ',
  'conduit':'コンジット','wattson':'ワットソン','catalyst':'カタリスト',
  'fuse':'ヒューズ','ballistic':'バリスティック','sparrow':'スパロー'
};
const CLS_MAP = {
  'ニューキャッスル':'cls-support','ヴァルキリー':'cls-recon','コースティック':'cls-controller',
  'バンガロール':'cls-assault','シア':'cls-recon','パスファインダー':'cls-skirmisher',
  'アッシュ':'cls-assault','ランパート':'cls-controller','マッドマギー':'cls-assault',
  'オルター':'cls-skirmisher','クリプト':'cls-recon','ブラッドハウンド':'cls-recon',
  'レイス':'cls-skirmisher','オクタン':'cls-skirmisher','ホライゾン':'cls-skirmisher',
  'レヴナント':'cls-skirmisher','ヴァンテージ':'cls-recon','ジブラルタル':'cls-support',
  'ライフライン':'cls-support','ミラージュ':'cls-support','ローバ':'cls-support',
  'コンジット':'cls-support','ワットソン':'cls-controller','カタリスト':'cls-controller',
  'ヒューズ':'cls-assault','バリスティック':'cls-assault','スパロー':'cls-recon'
};

let importGameNum = 1;
let parsedImportData = null;

function openImportModal() {
  document.getElementById('importOverlay').classList.add('visible');
  document.getElementById('importTextarea').value = '';
  document.getElementById('importPreview').style.display = 'none';
  parsedImportData = null;
}

function closeImportModal() {
  document.getElementById('importOverlay').classList.remove('visible');
}

document.getElementById('importGameBtns').addEventListener('click', function(e) {
  if (e.target.classList.contains('import-game-btn')) {
    document.querySelectorAll('.import-game-btn').forEach(b => b.classList.remove('active'));
    e.target.classList.add('active');
    importGameNum = parseInt(e.target.dataset.game);
    parseImportData();
  }
});

document.getElementById('importTextarea').addEventListener('input', parseImportData);
document.getElementById('importTextarea').addEventListener('paste', () => setTimeout(parseImportData, 50));

function parseImportData() {
  const text = document.getElementById('importTextarea').value.trim();
  if (!text) return;
  const lines = text.split('\n').filter(l => l.trim());
  const players = {};
  let placement = null;

  for (const line of lines) {
    const cols = line.split('\t');
    if (cols.length < 9) continue;
    const teamName = cols[0].toLowerCase().trim();
    if (teamName !== 'kinoko') continue;
    const playerName = cols[2].toLowerCase().trim();
    const charEn = cols[3].toLowerCase().trim();
    placement = parseInt(cols[4]);
    const kills = parseInt(cols[5]) || 0;
    const assists = parseInt(cols[6]) || 0;
    const damage = Math.round(parseFloat(cols[7])) || 0;
    const role = PLAYER_MAP[playerName] || null;
    if (!role) continue;
    const charJp = CHAR_MAP[charEn] || charEn;
    players[role] = { kills, assists, damage, char: charJp, placement };
  }

  if (Object.keys(players).length === 0) {
    document.getElementById('importPreview').style.display = 'block';
    document.getElementById('importPreview').innerHTML = '❌ kinokoのデータが見つかりません';
    parsedImportData = null;
    return;
  }

  parsedImportData = { players, placement };
  const pp = PLACEMENT_PTS[placement] || 0;
  const totalKills = (players.t?.kills||0) + (players.p?.kills||0) + (players.a?.kills||0);
  const totalPt = totalKills + pp;

  const prev = document.getElementById('importPreview');
  prev.style.display = 'block';
  prev.innerHTML = `
    <div style="margin-bottom:6px;font-weight:bold;">GAME ${importGameNum} — ${placement}位 / 順位PT: ${pp}</div>
    <div>Lykq: ${players.t?.char||'?'} | K:${players.t?.kills||0} A:${players.t?.assists||0} DMG:${(players.t?.damage||0).toLocaleString()}</div>
    <div>mo-mon: ${players.p?.char||'?'} | K:${players.p?.kills||0} A:${players.p?.assists||0} DMG:${(players.p?.damage||0).toLocaleString()}</div>
    <div>Lible_Ace: ${players.a?.char||'?'} | K:${players.a?.kills||0} A:${players.a?.assists||0} DMG:${(players.a?.damage||0).toLocaleString()}</div>
    <div style="margin-top:4px;color:#555;">TOTAL K:${totalKills} PT:${totalPt}</div>
  `;
}

function applyImport() {
  if (!parsedImportData) return;
  const { players, placement } = parsedImportData;
  const g = importGameNum - 1; // 0-indexed
  const pp = PLACEMENT_PTS[placement] || 0;
  const totalKills = (players.t?.kills||0) + (players.p?.kills||0) + (players.a?.kills||0);
  const totalPt = totalKills + pp;

  // Helper: get cells of a row by class, index g (each game = 4 cells, so offset = g*4)
  function getGameCells(rowClass, offset) {
    const rows = document.querySelectorAll(rowClass + ' td');
    // skip label cell, each game block is 4 cells
    const start = 1 + g * 4;
    return [rows[start], rows[start+1], rows[start+2], rows[start+3]];
  }

  // Result row: K, P, PT, 小計 (no label cell, offset = g*4)
  const resultCells = document.querySelectorAll('.row-result td');
  const rb = g * 4;
  if (resultCells[rb]) {
    resultCells[rb].textContent = totalKills;
    resultCells[rb].className = totalKills > 0 ? 'k-val' : 'k0-val';
  }
  if (resultCells[rb+1]) resultCells[rb+1].textContent = pp;
  if (resultCells[rb+2]) resultCells[rb+2].textContent = totalPt;

  // Rank row
  const rankCells = document.querySelectorAll('.rank-cell');
  if (rankCells[g]) {
    rankCells[g].textContent = placement + '位';
    rankCells[g].className = 'rank-cell ' + (placement <= 5 ? 'rank-good' : placement <= 10 ? 'rank-mid' : 'rank-bad');
  }

  // Update 小計 (running total) for all games
  updateSubtotals();

  // Kills row (no label cell - rowspan=2 in init row)
  const killCells = document.querySelectorAll('.row-kills td');
  const ks = g * 4;
  if (killCells[ks])   { killCells[ks].textContent = players.t?.kills||0; killCells[ks].className = 'kval c-t'; }
  if (killCells[ks+1]) { killCells[ks+1].textContent = players.p?.kills||0; killCells[ks+1].className = 'kval c-p'; }
  if (killCells[ks+2]) { killCells[ks+2].textContent = players.a?.kills||0; killCells[ks+2].className = 'kval c-a'; }
  if (killCells[ks+3]) killCells[ks+3].textContent = totalKills;

  // Assists row
  const astCells = document.querySelectorAll('.row-assists td');
  const as2 = 1 + g * 4;
  if (astCells[as2])   { astCells[as2].textContent = players.t?.assists||0; astCells[as2].className = 'kval c-t'; }
  if (astCells[as2+1]) { astCells[as2+1].textContent = players.p?.assists||0; astCells[as2+1].className = 'kval c-p'; }
  if (astCells[as2+2]) { astCells[as2+2].textContent = players.a?.assists||0; astCells[as2+2].className = 'kval c-a'; }
  if (astCells[as2+3]) astCells[as2+3].textContent = (players.t?.assists||0)+(players.p?.assists||0)+(players.a?.assists||0);

  // DMG row
  const dmgCells = document.querySelectorAll('.row-dmg td');
  const ds = 1 + g * 4;
  const totalDmg = (players.t?.damage||0)+(players.p?.damage||0)+(players.a?.damage||0);
  if (dmgCells[ds])   { dmgCells[ds].textContent = (players.t?.damage||0).toLocaleString(); dmgCells[ds].className = 'dmg c-t'; }
  if (dmgCells[ds+1]) { dmgCells[ds+1].textContent = (players.p?.damage||0).toLocaleString(); dmgCells[ds+1].className = 'dmg c-p'; }
  if (dmgCells[ds+2]) { dmgCells[ds+2].textContent = (players.a?.damage||0).toLocaleString(); dmgCells[ds+2].className = 'dmg c-a'; }
  if (dmgCells[ds+3]) dmgCells[ds+3].textContent = totalDmg.toLocaleString();

  // Character rows - update each player's char cell for this game
  updateCharCell('t', g, players.t?.char);
  updateCharCell('p', g, players.p?.char);
  updateCharCell('a', g, players.a?.char);
  mergeCharRow(0);
  mergeCharRow(1);
  mergeCharRow(2);

  // Update totals
  updateTotals();
  closeImportModal();
}

function updateCharCell(player, gameIdx, charName) {
  if (!charName) return;
  const charJp = charName;
  const cls = CLS_MAP[charJp] || 'char-cell';
  // Find the correct char-cell for this player and game
  // char rows: row-char has 3 rows (t, p, a)
  const charRows = document.querySelectorAll('.row-char');
  const playerIdx = player === 't' ? 0 : player === 'p' ? 1 : 2;
  const row = charRows[playerIdx];
  if (!row) return;
  // Each game = 4 cols span, need to find which merged cell covers this game
  // Since cells can be merged, we need to rebuild
  // Simple approach: expand all cells to individual, then remerge
  // Actually let's just mark this game's slot
  // We'll use a data approach: track per-game chars and rebuild the row
  const cells = row.querySelectorAll('td:not(.td-label)');
  // Calculate which cell covers game gameIdx (0-based)
  let col = 0;
  for (const cell of cells) {
    const span = parseInt(cell.getAttribute('colspan') || 4) / 4;
    if (gameIdx >= col && gameIdx < col + span) {
      // This cell covers our game - if span=1 just update, else split
      if (span === 1) {
        cell.textContent = charJp;
        cell.className = 'char-cell ' + cls;
      } else {
        // Need to split: replace with individual cells
        const parent = cell.parentNode;
        const ref = cell.nextSibling;
        for (let i = 0; i < span; i++) {
          const td = document.createElement('td');
          td.setAttribute('colspan', '4');
          td.className = 'char-cell ' + (i === gameIdx - col ? cls : (CLS_MAP[cell.textContent] || ''));
          td.textContent = i === gameIdx - col ? charJp : cell.textContent;
          td.style.cursor = 'pointer';
          td.addEventListener('click', function(e) {
            activeCharCell = this;
            activeBanCell = null;
            const picker = document.getElementById('charPicker');
            picker.style.left = (e.clientX + window.scrollX) + 'px';
            picker.style.top = (e.clientY + window.scrollY + 8) + 'px';
            picker.classList.add('visible');
            document.getElementById('imgUploadArea').style.display = 'none';
          });
          parent.insertBefore(td, ref);
        }
        parent.removeChild(cell);
      }
      break;
    }
    col += span;
  }
}


function mergeCharRow(playerIdx) {
  const charRows = document.querySelectorAll('.row-char');
  const row = charRows[playerIdx];
  if (!row) return;

  // Collect all 8 game slots
  const slots = Array(8).fill(null).map(() => ({ text: '—', cls: 'char-cell c-0' }));
  const cells = Array.from(row.querySelectorAll('td:not(.td-label)'));
  let col = 0;
  cells.forEach(cell => {
    const span = parseInt(cell.getAttribute('colspan') || 4) / 4;
    for (let i = 0; i < span; i++) {
      if (col + i < 8) slots[col + i] = { text: cell.textContent, cls: cell.className };
    }
    col += span;
  });

  // Remove existing cells (except label)
  cells.forEach(cell => cell.remove());

  // Rebuild merged cells
  let i = 0;
  while (i < 8) {
    let j = i + 1;
    while (j < 8 && slots[j].text === slots[i].text && slots[i].text !== '—') j++;
    const span = (j - i) * 4;
    const td = document.createElement('td');
    td.setAttribute('colspan', span);
    td.className = slots[i].cls;
    td.textContent = slots[i].text;
    td.style.cursor = 'pointer';
    td.addEventListener('click', function(e) {
      activeCharCell = this;
      activeBanCell = null;
      const picker = document.getElementById('charPicker');
      picker.style.left = (e.clientX + window.scrollX) + 'px';
      picker.style.top = (e.clientY + window.scrollY + 8) + 'px';
      picker.classList.add('visible');
      document.getElementById('imgUploadArea').style.display = 'none';
    });
    row.appendChild(td);
    i = j;
  }
}

function updateSubtotals() {
  const resultCells = document.querySelectorAll('.row-result td');
  // skip label (index 0), then groups of 4: K, P, PT, 小計
  // 小計 = cumulative total PT
  let running = 0;
  for (let g = 0; g < 8; g++) {
    const base = g * 4;
    if (!resultCells[base]) continue;
    const pt = parseInt(resultCells[base+2]?.textContent) || 0;
    running += isNaN(pt) ? 0 : pt;
    if (resultCells[base+3] && resultCells[base+3].textContent !== '—') {
      resultCells[base+3].textContent = running;
    }
  }
}

function updateTotals() {
  // Update header totals
  let totalK=0, totalP=0, totalPT=0;
  const resultCells = document.querySelectorAll('.row-result td');
  for (let g = 0; g < 8; g++) {
    const base = g * 4;
    if (!resultCells[base] || resultCells[base].textContent === '—') continue;
    totalK += parseInt(resultCells[base].textContent) || 0;
    totalP += parseInt(resultCells[base+1]?.textContent) || 0;
    totalPT += parseInt(resultCells[base+2]?.textContent) || 0;
  }
  // Update header bar - find the v spans
  const vSpans = document.querySelectorAll('.total-item .v');
  if (vSpans[0]) vSpans[0].textContent = totalK;
  if (vSpans[1]) vSpans[1].textContent = totalP;
  if (vSpans[2]) vSpans[2].textContent = totalPT;

  // Update kill/dmg totals column
  updateRowTotals('.row-kills', 8);
  updateRowTotals('.row-assists', 8);
  updateDmgTotals(8);
}

function updateRowTotals(rowClass, numGames) {
  const cells = document.querySelectorAll(rowClass + ' td');
  let tT=0, tP=0, tA=0;
  const labelOffset = (rowClass === '.row-kills') ? 0 : 1;
  for (let g = 0; g < numGames; g++) {
    const base = labelOffset + g * 4;
    if (!cells[base] || cells[base].textContent === '—') continue;
    tT += parseInt(cells[base].textContent) || 0;
    tP += parseInt(cells[base+1]?.textContent) || 0;
    tA += parseInt(cells[base+2]?.textContent) || 0;
  }
  // kills row has no label; assists row has label - caller passes offset
  const totalBase = (rowClass === '.row-kills') ? 8 * 4 : 1 + 8 * 4;
  if (cells[totalBase]) cells[totalBase].textContent = tT;
  if (cells[totalBase+1]) cells[totalBase+1].textContent = tP;
  if (cells[totalBase+2]) cells[totalBase+2].textContent = tA;
}

function updateDmgTotals(numGames) {
  const cells = document.querySelectorAll('.row-dmg td');
  let tT=0, tP=0, tA=0;
  for (let g = 0; g < numGames; g++) {
    const base = 1 + g * 4;
    if (!cells[base] || cells[base].textContent === '—') continue;
    tT += parseInt((cells[base].textContent||'0').replace(/,/g,'')) || 0;
    tP += parseInt((cells[base+1]?.textContent||'0').replace(/,/g,'')) || 0;
    tA += parseInt((cells[base+2]?.textContent||'0').replace(/,/g,'')) || 0;
  }
  const totalBase = 1 + 8 * 4;
  if (cells[totalBase]) cells[totalBase].textContent = tT.toLocaleString();
  if (cells[totalBase+1]) cells[totalBase+1].textContent = tP.toLocaleString();
  if (cells[totalBase+2]) cells[totalBase+2].textContent = tA.toLocaleString();
}

function applyBanCarryover(gameNum) {
  // carryover disabled
}

// BAN picker
let activeBanCell = null;

document.querySelectorAll('.ban-cell').forEach(td => {
  td.style.cursor = 'pointer';
  td.addEventListener('click', function(e) {
    e.stopPropagation();
    activeBanCell = this;
    activeCharCell = null;
    const picker = document.getElementById('charPicker');
    picker.style.left = (e.clientX + window.scrollX) + 'px';
    picker.style.top = (e.clientY + window.scrollY + 8) + 'px';
    picker.dataset.mode = 'ban';
    picker.classList.add('visible');
    document.getElementById('imgUploadArea').style.display = 'block';
    setTimeout(() => document.getElementById('pasteTarget').focus(), 50);
  });
});


// POI picker
let activePoiCell = null;

document.querySelectorAll('.poi-cell').forEach(td => {
  td.style.cursor = 'pointer';
  td.addEventListener('click', function(e) {
    e.stopPropagation();
    activePoiCell = this;
    const picker = document.getElementById('poiPicker');
    picker.style.left = Math.min(e.clientX + window.scrollX, window.innerWidth - 240) + 'px';
    picker.style.top = (e.clientY + window.scrollY + 8) + 'px';
    picker.classList.add('visible');
  });
});

function selectPoi(el) {
  if (!activePoiCell) return;
  activePoiCell.textContent = el.textContent;
  // trigger merge
  mergePOI();
  closePoiPicker();
}

function clearPoiCell() {
  if (!activePoiCell) return;
  activePoiCell.textContent = '—';
  mergePOI();
  closePoiPicker();
}

function closePoiPicker() {
  document.getElementById('poiPicker').classList.remove('visible');
  activePoiCell = null;
}

document.addEventListener('click', function(e) {
  const picker = document.getElementById('poiPicker');
  if (picker && !picker.contains(e.target) && !e.target.classList.contains('poi-cell')) {
    closePoiPicker();
  }
});

// POI auto-merge
function mergePOI() {
  const row = document.getElementById('poi-row');
  if (!row) return;

  // Collect current values (expand merged cells back to 8 slots)
  const slots = Array(8).fill('');
  let slotIdx = 0;
  const cells = Array.from(row.querySelectorAll('.poi-cell'));
  cells.forEach(td => {
    const span = parseInt(td.getAttribute('colspan')) / 4;
    const val = td.innerText.trim();
    for (let i = 0; i < span; i++) slots[slotIdx++] = val;
  });

  // Remove existing poi cells
  cells.forEach(td => td.remove());
  // Remove total cell temporarily
  const totalCell = row.querySelector('.td-total-col');
  if (totalCell) totalCell.remove();

  // Build merged cells
  let i = 0;
  while (i < 8) {
    let j = i + 1;
    while (j < 8 && slots[j] === slots[i] && slots[i] !== '—' && slots[i] !== '') j++;
    const span = (j - i) * 4;
    const td = document.createElement('td');
    td.className = 'poi-cell';
    td.setAttribute('colspan', span);
    td.setAttribute('data-game', i + 1);
    td.innerText = slots[i];
    td.addEventListener('blur', mergePOI);
    td.style.cursor = 'pointer';
    td.addEventListener('click', function(e) {
      e.stopPropagation();
      activePoiCell = this;
      const picker = document.getElementById('poiPicker');
      picker.style.left = Math.min(e.clientX + window.scrollX, window.innerWidth - 240) + 'px';
      picker.style.top = (e.clientY + window.scrollY + 8) + 'px';
      picker.classList.add('visible');
    });
    row.appendChild(td);
    i = j;
  }

  // Re-add total cell
  const tc = document.createElement('td');
  tc.className = 'td-total-col';
  tc.setAttribute('colspan', '3');
  row.appendChild(tc);
}

// Attach listeners to initial POI cells
document.querySelectorAll('.poi-cell').forEach(td => {
  td.addEventListener('blur', mergePOI);
});

// 今日の日付を自動セット
(function() {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth()+1).padStart(2,'0');
  const day = String(d.getDate()).padStart(2,'0');
  document.getElementById("meta-date").value = y+"/"+m+"/"+day;
})();

function updateHeader() {
  const dateStr = document.getElementById("meta-date").value;
  const scrim = document.getElementById("meta-scrim").value;
  const numRaw = document.getElementById("meta-num").value.trim();
  const prefix = document.getElementById("meta-prefix").value;
  const num = numRaw ? prefix + numRaw : "";

  // Add day of week to date
  const days = ["日","月","火","水","木","金","土"];
  let dateWithDay = dateStr;
  if (dateStr) {
    const d = new Date(dateStr.replace(/\//g, "-"));
    if (!isNaN(d)) dateWithDay = dateStr + " (" + days[d.getDay()] + ")";
  }

  const parts = [dateWithDay, scrim, num].filter(v => v && v.trim());
  document.getElementById("header-sub").textContent =
    parts.length ? parts.join("  |  ") : "FIGHT NT by ESCL — SCRIM SHEET";
}
["meta-date","meta-scrim","meta-num","meta-prefix"].forEach(id => {
  document.getElementById(id).addEventListener("input", updateHeader);
  document.getElementById(id).addEventListener("change", updateHeader);
});
updateHeader();

// Final Place click to edit
document.getElementById('total-finalplace').addEventListener('click', function() {
  const current = this.textContent.trim();
  const val = prompt('Final Place（最終順位）:', current === '—' ? '' : current);
  if (val === null) return;
  this.textContent = val.trim() === '' ? '—' : val.trim();
});
document.getElementById('total-finalplace').style.cursor = 'pointer';


const MAP_NAMES = ['Storm Point','World\'s Edge','Olympus','E-District','Broken Moon','King\'s Canyon'];
let activeMapCell = null;

const mapPicker = document.createElement('div');
mapPicker.id = 'mapPicker';
mapPicker.style.cssText = 'display:none;position:fixed;z-index:2000;background:#fff;border:1px solid #c4c4c4;border-radius:6px;box-shadow:0 4px 16px rgba(0,0,0,0.15);padding:6px;min-width:160px;';
MAP_NAMES.forEach(name => {
  const item = document.createElement('div');
  item.textContent = name;
  item.style.cssText = 'font-family:"Noto Sans JP",sans-serif;font-size:11px;padding:6px 10px;cursor:pointer;border-radius:3px;';
  item.onmouseover = () => item.style.background = '#f0f0f0';
  item.onmouseout = () => item.style.background = '';
  item.onclick = (e) => {
    e.stopPropagation();
    if (activeMapCell) activeMapCell.textContent = name;
    mapPicker.style.display = 'none';
    activeMapCell = null;
    mergeMap();
  };
  mapPicker.appendChild(item);
});
const mapClear = document.createElement('div');
mapClear.textContent = 'クリア（—に戻す）';
mapClear.style.cssText = 'font-family:"Noto Sans JP",sans-serif;font-size:10px;padding:5px 10px;cursor:pointer;border-top:1px solid #eee;margin-top:4px;color:#888;border-radius:3px;';
mapClear.onclick = (e) => {
  e.stopPropagation();
  if (activeMapCell) activeMapCell.textContent = '—';
  mapPicker.style.display = 'none';
  activeMapCell = null;
  mergeMap();
};
mapPicker.appendChild(mapClear);
document.body.appendChild(mapPicker);

function attachMapCellListeners() {
  document.querySelectorAll('.map-cell').forEach(td => {
    td.style.cursor = 'pointer';
    td.onclick = function(e) {
      e.stopPropagation();
      activeMapCell = this;
      mapPicker.style.left = (e.clientX + window.scrollX) + 'px';
      mapPicker.style.top = (e.clientY + window.scrollY + 8) + 'px';
      mapPicker.style.display = 'block';
    };
  });
}
attachMapCellListeners();

function mergeMap() {
  const row = document.querySelector('.row-map');
  if (!row) return;
  const slots = Array(8).fill('—');
  let idx = 0;
  Array.from(row.querySelectorAll('.map-cell')).forEach(td => {
    const span = parseInt(td.getAttribute('colspan')) / 4;
    const val = td.textContent.trim() || '—';
    for (let i = 0; i < span; i++) slots[idx++] = val;
  });
  row.querySelectorAll('.map-cell').forEach(td => td.remove());
  const totalCell = row.querySelector('.td-total-col');
  if (totalCell) totalCell.remove();
  let i = 0;
  while (i < 8) {
    let j = i + 1;
    while (j < 8 && slots[j] === slots[i] && slots[i] !== '—') j++;
    const td = document.createElement('td');
    td.className = 'map-cell';
    td.setAttribute('colspan', (j - i) * 4);
    td.setAttribute('data-game', i + 1);
    td.textContent = slots[i];
    row.appendChild(td);
    i = j;
  }
  const tc = document.createElement('td');
  tc.className = 'td-total-col';
  tc.setAttribute('colspan', '3');
  row.appendChild(tc);
  attachMapCellListeners();
}

document.addEventListener('click', () => {
  mapPicker.style.display = 'none';
  activeMapCell = null;
});
</script>
</body>
</html>
